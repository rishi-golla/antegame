# === Chain Config ===
# "base-sepolia" for testnet, "base-mainnet" for production
NEXT_PUBLIC_CHAIN_ENV=base-sepolia
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org

# === Contract Addresses (set after deployment) ===
NEXT_PUBLIC_MONOPOLY_GAME_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# === Server-side (same contract address, no NEXT_PUBLIC_ prefix) ===
CHAIN_ENV=base-sepolia
BASE_RPC_URL=https://sepolia.base.org
MONOPOLY_GAME_ADDRESS=0x0000000000000000000000000000000000000000

# === Game Signer (server holds this key to sign settlements/cancellations) ===
# This MUST match the gameSigner set in the MonopolyGame contract constructor
# Generate with: cast wallet new
GAME_SIGNER_PRIVATE_KEY=0x...

# === Legacy Solana Config (still used for free play / existing flow) ===
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_ESCROW_ADDRESS=
SOLANA_RPC_URL=https://api.devnet.solana.com

# === WalletConnect (optional) ===
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
