# === Required for Production ===

# Node environment
NODE_ENV=production

# Server port (Railway sets this automatically)
# PORT=3000

# CORS origins — your production domain(s), comma-separated
CORS_ORIGINS=https://ante.wtf

# Admin wallet for referral payouts and admin endpoints
ADMIN_WALLET=0xYourWalletAddress

# === Blockchain ===

# Chain environment: base-mainnet or base-sepolia
CHAIN_ENV=base-mainnet

# Alchemy RPC (server-side only — NOT exposed to client)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deployed contract addresses
MONOPOLY_GAME_ADDRESS=0x...
# NEXT_PUBLIC_ versions for client-side contract reads
NEXT_PUBLIC_CHAIN_ENV=base-mainnet
NEXT_PUBLIC_MONOPOLY_GAME_ADDRESS=0x...
NEXT_PUBLIC_FEE_VAULT_ADDRESS=0x...

# Game signer private key (for signing settlement/cancellation messages)
# Prefer ~/.config/ante/keys.json on VPS; use env var on Railway
GAME_SIGNER_PRIVATE_KEY=0x...

# === Optional ===

# Solana RPC (if using Solana path)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Winner payout multiplier (default: 2)
# WINNER_MULTIPLIER=2

# Solana RPC for bridge feature
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Referral campaign start time (ISO 8601). First 24h = 50% referral rate, then 10%.
# Campaign leaderboard runs for 7 days from this time.
CAMPAIGN_START_UTC=2026-03-01T00:00:00Z
